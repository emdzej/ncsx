{
  "name": "ncsx",
  "private": true,
  "version": "0.5.0",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "ci": "turbo run build lint typecheck test",
    "clean": "turbo run clean",
    "web": "pnpm --filter @emdzej/ncsx-web dev",
    "web:build": "pnpm --filter @emdzej/ncsx-web build",
    "web:preview": "pnpm --filter @emdzej/ncsx-web preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.1",
    "eslint": "^9.19.0",
    "prettier": "^3.5.1",
    "turbo": "^2.8.10",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ncsx.git"
  }
}
