{
  "name": "@emdzej/ncsx-inpax-cabi-provider",
  "version": "0.5.0",
  "description": "CABI/CDH bridge for the inpax IPO interpreter — implements the 80+ CDH* functions NCSEXPER's A_*.ipo dispatchers call (statically linked in NCSEXPER.EXE). Signatures from CABI.H, behaviour ghidra-verified per docs/assumptions.md.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@emdzej/ncsx-chassis": "workspace:*",
    "@emdzej/ncsx-fa-asw": "workspace:*",
    "@emdzej/ncsx-wire": "workspace:*"
  },
  "peerDependencies": {
    "@emdzej/bimmerz-logger": "^0.1.2"
  },
  "devDependencies": {
    "@emdzej/bimmerz-logger": "^0.1.2",
    "@types/node": "^22.13.1",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ncsx.git",
    "directory": "packages/inpax-cabi-provider"
  }
}
