{
  "name": "@emdzej/ncsx-cli",
  "version": "0.1.0",
  "description": "Command-line companion to @emdzej/ncsx-web. First-class commands for working with .ncsxpatch.yaml files and converting to/from NCSEXPER's .MAN format.",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "ncsx": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "ncsx": "node dist/cli.js"
  },
  "dependencies": {
    "@emdzej/ncsx-patches": "workspace:*",
    "@emdzej/ncsx-trace": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ncsx.git",
    "directory": "apps/cli"
  }
}
